<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Task Manager<% if (workspace) { %> - <%= workspace.name %><% } %></title>
  <meta name="description" content="軽量・高速なタスク管理ツール。">
  <!-- 数式(mathjax) -->
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js" onload="try{MDForceRender()}catch(e){}"></script>
    <script>
      window.MathJax = {
        tex: {
          inlineMath: [['$', '$'], ['\\(', '\\)']], // インライン数式用
          displayMath: [['$$', '$$'], ['\\[', '\\]']] // ブロック数式用
        },
        options: {
          skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code']
        }
      };
    </script>
  <!-- マークダウンパーサ -->
    <script src="https://cdn.jsdelivr.net/npm/marked/lib/marked.umd.js" async onload="try{MDForceRender()}catch(e){}"></script>
  <!-- ハイライト -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.7.0/styles/nord.min.css" async>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.7.0/highlight.min.js" async onload="try{MDForceRender()}catch(e){}"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" async>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin async>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" async>
  <link rel="stylesheet" href="/style.css" async>
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>
<body>
<script>
  // ===== constants =====
  const PRIORITY_COLORS=['#4b4b5e','#3b6ea0','#2e86c1','#d4ac0d','#e67e22','#e74c3c'];
  const PRIORITY_LABELS = ['最低','','','中','','最高'];
  const STATE = {
    workspaceId: <%- workspace ? workspace.id : 'null' %>,
    currentTaskId: <%- (tasks && tasks.length > 0) ? tasks[0].id : 'null' %>,
    tasks: <%- JSON.stringify(tasks || []) %>,
    lists: <%- JSON.stringify(lists || []) %>,
    userId: 1,  // TODO: 認証実装後に差し替え
    savingTitle: false,
  };
  const STATUS_COLORS = {
    '未着手': '#7a7a8e', '着手中': '#5b7cf7', '凍結': '#f5a623', '完了': '#3ecf8e'
  };
  const REMINDER_LABELS = {
    '30min': '30分前', '1hour': '1時間前', '3hours': '3時間前',
    '12hours': '12時間前', '1day': '1日前', '3days': '3日前', '1week': '1週間前'
  };
  const REMINDER_OFFSETS = {
    '30min': 30 * 60 * 1000,
    '1hour': 60 * 60 * 1000,
    '3hours': 3 * 60 * 60 * 1000,
    '12hours': 12 * 60 * 60 * 1000,
    '1day': 24 * 60 * 60 * 1000,
    '3days': 3 * 24 * 60 * 60 * 1000,
    '1week': 7 * 24 * 60 * 60 * 1000
  };
</script>
<script src="FE.js"></script>
<div class="layout">
  <!-- ── Sidebar ── -->
  <nav class="sidebar" aria-label="サイドバー">
    <button class="sidebar-btn accent" id="togglePanelBtn" onclick="togglePanel()" title="パネルを開く" aria-expanded="false">☰</button>
    <button class="sidebar-btn" onclick="openNewTaskModal()" title="新規タスク作成" id="sidebarNewBtn" style="margin-top:auto">＋</button>
  </nav>
  <!-- ── Overlay ── -->
  <div class="overlay" id="overlay" onclick="togglePanel()"></div>
  <!-- ── Side Panel ── -->
  <aside class="side-panel" id="sidePanel" aria-label="タスクパネル">
    <div class="panel-header">
      <button class="panel-workspace-name" id="workspaceName" type="button" onclick="openWorkspaceManagerModal()" title="ワークスペースを管理">
        <%= workspace?.name || 'ワークスペース' %>
      </button>
      <div class="panel-header-actions">
        <button class="workspace-add-btn" type="button" onclick="openWorkspaceModal()" title="ワークスペースを追加" aria-label="ワークスペースを追加">＋</button>
        <button class="panel-close" onclick="togglePanel()" title="閉じる" aria-label="パネルを閉じる">✕</button>
      </div>
    </div>
    <button class="new-task-btn" onclick="openNewTaskModal()" id="newTaskBtn">
      <span>＋</span> 新規タスク
    </button>
    <div class="panel-body" id="panelBody">
      <% if (lists && lists.length > 0) { %>
        <% lists.forEach((list) => { %>
          <div class="list-section" id="list-section-<%= list.id %>">
            <div class="list-label">
              <span class="list-dot" style="background:<%= list.color || '#5b7cf7' %>"></span>
              <%= list.name %>
            </div>
            <% const listTasks = tasks.filter(t => t.listId === list.id); %>
            <% if (listTasks.length === 0) { %>
              <div style="padding:6px 14px 10px; font-size:12px; color:var(--text-2);">タスクなし</div>
            <% } %>
            <% listTasks.forEach((task) => { %>
              <div class="task-item" id="task-item-<%= task.id %>" onclick="selectTask(<%= task.id %>)">
                <div class="task-item-title"><%= task.title %></div>
                <div class="task-item-meta">
                  <span class="status-badge status-<%= task.status %>"><%= task.status %></span>
                  <% if (task.dueDate) { %>
                    <span><%= new Date(task.dueDate).toLocaleDateString('ja-JP', {month:'numeric',day:'numeric'}) %></span>
                  <% } %>
                </div>
              </div>
            <% }); %>
          </div>
        <% }); %>
      <% } else { %>
        <div class="panel-empty">
          タスクリストがありません。<br>初期化ボタンでセットアップできます。
        </div>
      <% } %>
    </div>
  </aside>
  <!-- ── Main Area ── -->
  <main class="main-area" id="mainArea">
    <% if (workspace && tasks && tasks.length > 0) { %>
    <script >selectTask(<%= tasks[0].id%>)</script>
    <% } %>
  </main>
</div>
<!-- ── Task Create Modal ── -->
<div class="modal-backdrop" id="modalBackdrop" role="dialog" aria-modal="true" aria-labelledby="modalTitle" onclick="function(e) {if (e.target === this) closeModal();}">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <span class="modal-title" id="modalTitle">新規タスク作成</span>
      <button class="modal-close-btn" onclick="closeModal()" aria-label="モーダルを閉じる">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-field">
        <label class="form-label" for="inputTitle">タスク名 <span style="color:var(--red)">*</span></label>
        <input class="form-input" id="inputTitle" type="text" placeholder="タスクのタイトルを入力..." autocomplete="off">
      </div>
      <div class="form-field">
        <label class="form-label" for="inputList">リスト</label>
        <select class="form-select" id="inputList">
          <% if (lists && lists.length > 0) { %>
            <% lists.forEach(list => { %>
              <option value="<%= list.id %>"><%= list.name %></option>
            <% }); %>
          <% } else { %>
            <option value="">（リストなし）</option>
          <% } %>
        </select>
      </div>
      <div class="form-row">
        <div class="form-field">
          <label class="form-label" for="inputStatus">ステータス</label>
          <select class="form-select" id="inputStatus">
            <option value="未着手">未着手</option>
            <option value="着手中">着手中</option>
            <option value="凍結">凍結</option>
            <option value="完了">完了</option>
          </select>
        </div>
        <div class="form-field">
          <label class="form-label" for="inputPriority">優先度</label>
          <select class="form-select" id="inputPriority">
            <option value="0">0 - 最低</option>
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3" selected>3 - 中</option>
            <option value="4">4</option>
            <option value="5">5 - 最高</option>
          </select>
        </div>
      </div>
      <div class="form-field">
        <label class="form-label" for="inputDueDate">期限（任意）</label>
        <input class="form-input" id="inputDueDate" type="datetime-local">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal()">キャンセル</button>
      <button class="btn btn-primary" id="createBtn" onclick="createTask()">作成</button>
    </div>
  </div>
</div>
<!-- ── Workspace Manager Modal ── -->
<div class="modal-backdrop" id="workspaceManagerModalBackdrop" role="dialog" aria-modal="true" aria-labelledby="workspaceManagerModalTitle",onclick="function(e) {if (e.target === this) closeWorkspaceManagerModal();}">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <span class="modal-title" id="workspaceManagerModalTitle">ワークスペースを管理</span>
      <button class="modal-close-btn" onclick="closeWorkspaceManagerModal()" aria-label="モーダルを閉じる">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-field">
        <label class="form-label" for="workspaceSelect">ワークスペースを切り替え</label>
        <select class="form-select" id="workspaceSelect" onchange="switchWorkspace(this.value)"></select>
      </div>
      <div class="form-field">
        <label class="form-label" for="editWorkspaceName">ワークスペース名 <span style="color:var(--red)">*</span></label>
        <input class="form-input" id="editWorkspaceName" type="text" autocomplete="off">
      </div>
      <div class="form-field">
        <label class="form-label" for="editWorkspaceDescription">説明（任意）</label>
        <input class="form-input" id="editWorkspaceDescription" type="text" autocomplete="off">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-danger" id="deleteWorkspaceBtn" onclick="deleteCurrentWorkspace()">このワークスペースを削除</button>
      <button class="btn btn-ghost" onclick="closeWorkspaceManagerModal()">キャンセル</button>
      <button class="btn btn-primary" id="saveWorkspaceBtn" onclick="saveCurrentWorkspace()">保存</button>
    </div>
  </div>
</div>
<!-- ── Workspace Create Modal ── -->
<div class="modal-backdrop" id="workspaceModalBackdrop" role="dialog" aria-modal="true" aria-labelledby="workspaceModalTitle",onclick="function(e) {if (e.target === this) closeWorkspaceModal();}">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <span class="modal-title" id="workspaceModalTitle">ワークスペースを追加</span>
      <button class="modal-close-btn" onclick="closeWorkspaceModal()" aria-label="モーダルを閉じる">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-field">
        <label class="form-label" for="inputWorkspaceName">ワークスペース名 <span style="color:var(--red)">*</span></label>
        <input class="form-input" id="inputWorkspaceName" type="text" placeholder="例：個人プロジェクト" autocomplete="off">
      </div>
      <div class="form-field">
        <label class="form-label" for="inputWorkspaceDescription">説明（任意）</label>
        <input class="form-input" id="inputWorkspaceDescription" type="text" placeholder="ワークスペースの説明を入力..." autocomplete="off">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeWorkspaceModal()">キャンセル</button>
      <button class="btn btn-primary" id="createWorkspaceBtn" onclick="createWorkspace()">追加</button>
    </div>
  </div>
</div>
<!-- ── Meta Popups ── -->
<!-- Status Popup -->
<div class="meta-popup" id="popup-status" style="display:none" role="dialog" aria-label="ステータス選択">
  <div class="meta-popup-header">ステータス</div>
  <div class="status-add-row">
    <input class="status-add-input" id="statusAddInput" type="text" placeholder="新しいステータスを追加..."
           onkeydown="if(event.key==='Enter')addCustomStatus()">
    <button class="status-add-btn" onclick="addCustomStatus()">追加</button>
  </div>
  <div id="statusOptionList"></div>
</div>
<!-- Priority Popup -->
<div class="meta-popup" id="popup-priority" style="display:none" role="dialog" aria-label="優先度選択">
  <div class="meta-popup-header">優先度 (0 = 最低 / 5 = 最高)</div>
  <div class="priority-grid" id="priorityGrid"></div>
</div>
<!-- Progress Popup -->
<div class="meta-popup" id="popup-progress" style="display:none" role="dialog" aria-label="進捗入力">
  <div class="meta-popup-header">進捗</div>
  <div class="progress-body">
    <div class="progress-number-row">
      <input class="progress-num-input" id="progressNumInput" type="number" min="0" max="100" value="0"
             oninput="syncProgressSlider()">
      <span style="font-size:14px;color:var(--text-2)">%</span>
    </div>
    <input class="progress-slider" id="progressSlider" type="range" min="0" max="100" value="0"
           oninput="syncProgressNum()">
    <div class="progress-bar-track">
      <div class="progress-bar-fill" id="progressBarFill" style="width:0%"></div>
    </div>
    <button class="progress-save-btn" onclick="saveProgress()">保存</button>
  </div>
</div>
<!-- Reminder Popup -->
<div class="meta-popup" id="popup-reminder" style="display:none" role="dialog" aria-label="リマインダー設定">
  <div class="meta-popup-header">リマインダー</div>
  <div class="reminder-body">
    <div class="reminder-add-row">
      <select class="reminder-select" id="reminderPresetInput" aria-label="期限前のリマインダー">
        <option value="30min">30分前</option>
        <option value="1hour">1時間前</option>
        <option value="3hours">3時間前</option>
        <option value="12hours">12時間前</option>
        <option value="1day">1日前</option>
        <option value="3days">3日前</option>
        <option value="1week">1週間前</option>
      </select>
      <button class="duedate-save-btn" onclick="addPresetReminder()">追加</button>
    </div>
    <div class="reminder-custom-row">
      <span class="reminder-custom-label">日時を指定（時計）</span>
      <div class="reminder-add-row">
        <input class="duedate-input" id="reminderCustomInput" type="datetime-local" aria-label="リマインダー日時">
        <button class="duedate-save-btn" onclick="addCustomReminder()">追加</button>
      </div>
    </div>
    <div class="reminder-list" id="reminderList"></div>
    <button class="reminder-enable-btn" type="button" onclick="enableReminderAlerts()">通知音・ブラウザ通知を有効化</button>
  </div>
</div>
<!-- DueDate Popup -->
<div class="meta-popup" id="popup-duedate" style="display:none" role="dialog" aria-label="期限設定">
  <div class="meta-popup-header">期限</div>
  <div class="duedate-body">
    <input class="duedate-input" id="dueDateInput" type="datetime-local">
    <div class="duedate-btns">
      <button class="duedate-clear-btn" onclick="clearDueDate()">クリア</button>
      <button class="duedate-save-btn" onclick="saveDueDate()">保存</button>
    </div>
  </div>
</div>
<!-- ── Toast ── -->
<div class="toast" id="toast"></div>
</body>
</html>
